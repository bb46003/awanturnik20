<div class="flexcol">
    {{#each atrybuty as |atrybut|}}
        <div class="attribute-group">
            <div class="attribute-main">
                <a data-action="rzut_atrybut" data-atrybut="{{atrybut.name}}">{{localize atrybut.fields.value.label}}</a>
                <div class="flexrow atr-um">
                    {{formInput
                        atrybut.fields.value
                        value=(lookup (lookup @root.system.atrybuty atrybut.name) "value")
                        type="number"
                    }}
                </div>
            </div>
        </div>
    {{/each}}
</div>